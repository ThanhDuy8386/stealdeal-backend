{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "StealDeal.Identity",
    "Audience": "StealDeal.Client",
    "Secret": "CHANGE_THIS_TO_A_LONG_SECRET_AT_LEAST_32_CHARACTERS",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "ConnectionStrings": {
    "OrderDb": "Server=localhost;Database=StealDealOrderDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest"
  },
  "Outbox": {
    "BatchSize": 20,
    "PollingIntervalSeconds": 10,
    "MaxRetryCount": 5
  }
}